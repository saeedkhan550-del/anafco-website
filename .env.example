# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Your live site's base URL (no trailing slash). Set this AFTER your first
# deploy, once you know your real URL, e.g. https://anafco.vercel.app
# Drives metadata, canonical URLs, sitemap.xml and robots.txt.
NEXT_PUBLIC_SITE_URL=

# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Optional — only needed for meta-tag verify.
NEXT_PUBLIC_GOOGLE_VERIFICATION=
